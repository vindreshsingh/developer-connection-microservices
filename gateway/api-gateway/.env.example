PORT=4000
# The existing monolith the gateway fronts during the Strangler-Fig phase (M1).
MONOLITH_URL=http://localhost:3008
# Must match the monolith's JWT_SECRET so edge-auth verifies the same tokens.
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173
# Trusted header the gateway injects after verifying the JWT (downstream reads it).
INTERNAL_AUTH_HEADER=x-internal-user
NODE_ENV=development

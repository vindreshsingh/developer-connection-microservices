# realtime-gateway — Socket.IO front door (M5)
PORT=4020

# Shared DB (shared-DB phase) — same MongoDB as the monolith
MONGO_URI=mongodb://localhost:27017/developer-connection

# Must match the monolith's JWT secret — the gateway verifies the `token`
# cookie on the WS handshake itself (no internal header on raw upgrades).
JWT_SECRET=change-me

# CORS origin for the Socket.IO server
FRONTEND_URL=http://localhost:5173

# Optional. With Redis: cross-instance fan-out + cluster-wide presence, and
# REST services can push events into rooms here via @dc/realtime. Without it,
# the gateway runs single-instance and cross-process emits are no-ops.
# REDIS_URL=redis://localhost:6379

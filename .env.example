# Shared local dev defaults — copy to .env per service or use docker-compose.
NODE_ENV=development
JWT_SECRET=change-me
MONGO_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:5173
# Internal header the gateway signs after verifying the JWT.
INTERNAL_AUTH_HEADER=x-internal-user
# Observability — optional. When set, every service/gateway reports 5xx errors
# to Sentry (tagged with the service name). Unset = no-op (local dev/test/CI).
SENTRY_DSN=

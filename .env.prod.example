# ============================================================================
# Production env template. Copy to `.env` and fill REAL values.
#   cp .env.prod.example .env   &&   nano .env
# The real `.env` must be git-ignored (never commit secrets).
# docker-compose.prod.yml reads these automatically.
# ============================================================================

# --- Self-generated secrets (run: openssl rand -hex 32) -----------------------
# JWT_SECRET & INTERNAL_SERVICE_TOKEN must be identical across all services.
JWT_SECRET=
CSRF_SECRET=
INTERNAL_SERVICE_TOKEN=
# ENCRYPTION_KEY must be exactly 64 hex chars (openssl rand -hex 32).
ENCRYPTION_KEY=

# --- MongoDB Atlas ------------------------------------------------------------
# Base connection string WITHOUT a database name. Compose appends /identity,
# /profile, /chat, etc. per service.
# e.g. mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net
MONGO_BASE=

# --- Redis (Upstash) — OPTIONAL (unset = in-memory fallback) ------------------
# e.g. rediss://default:PASS@xxxxx.upstash.io:6379
REDIS_URL=

# --- Public URLs --------------------------------------------------------------
# Frontend origin (CORS). IP for now, domain later. No trailing slash.
FRONTEND_URL=http://YOUR_EC2_IP
# Gateway's PUBLIC base URL (used for OAuth redirects).
OAUTH_CALLBACK_BASE_URL=http://YOUR_EC2_IP:4000

# --- Email (OPTIONAL) — set SKIP_EMAIL_VERIFICATION=false once configured -----
SKIP_EMAIL_VERIFICATION=true
EMAIL_USER=
EMAIL_PASS=

# --- AI service (OPTIONAL) ----------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_DAILY_LIMIT=20

# --- Premium allowlist (OPTIONAL — test/comp accounts get Premium free) -------
# Comma-separated userIds and/or emails. userId match works for every premium
# feature (AI, calls, swipes, filters); email matches only where available.
# e.g. PREMIUM_ALLOWLIST=6a3e7fa4e6114a8fbf2bf4cd,tester@example.com
PREMIUM_ALLOWLIST=

# --- Cloudinary (OPTIONAL — image/resume uploads) -----------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Razorpay (OPTIONAL — payments) -------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- LiveKit (OPTIONAL — group video calls) -----------------------------------
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- OAuth logins (OPTIONAL) --------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Sentry (OPTIONAL — error tracking) ---------------------------------------
SENTRY_DSN=

# call-service — call lifecycle + LiveKit tokens REST (M5)
PORT=4006

# Shared DB (shared-DB phase) — same MongoDB as the monolith
MONGO_URI=mongodb://localhost:27017/developer-connection

# Must match the monolith's JWT secret (gateway verifies, forwards internal headers)
JWT_SECRET=change-me

# Required to push REST-side realtime events (call_incoming, call_ended, ...)
# into the realtime-gateway's rooms. Without it, those emits are no-ops.
# REDIS_URL=redis://localhost:6379

# LiveKit (group calls). Without these, /calls/group-token returns 503.
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

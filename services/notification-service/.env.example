PORT=4010
# M2 (shared-DB phase): point at the SAME MongoDB + database as the monolith so
# reads stay consistent while the monolith still writes notifications.
# Later (M6) this service gets its own database.
MONGO_URI=mongodb://localhost:27017/ChatApp
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
INTERNAL_AUTH_HEADER=x-internal-user

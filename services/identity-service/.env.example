# identity-service — accounts, auth, OAuth, JWT issuance (M6)
PORT=4001

# Shared DB (shared-DB phase) — same MongoDB as the monolith.
# (The standalone identity DB comes with the M6 DB-split step.)
MONGO_URI=mongodb://localhost:27017/developer-connection

# Must match every other service's JWT secret — identity mints the token here.
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173

# Optional. With Redis, transactional emails go to the shared `email` BullMQ
# queue (drained by the existing worker). Without it, emails send inline.
# REDIS_URL=redis://localhost:6379

# Skip email verification (local/dev). 'true' marks new accounts verified.
SKIP_EMAIL_VERIFICATION=false

# SMTP (Gmail app password) for verification + password-reset emails.
EMAIL_USER=
EMAIL_PASS=

# AES-256-GCM key for OAuth access tokens at rest (64 hex chars). Must match the
# monolith's key so existing encrypted tokens stay readable.
ENCRYPTION_KEY=

# OAuth — callback base must be the PUBLIC GATEWAY origin so providers redirect
# back through the gateway, which proxies /auth/oauth/* here.
OAUTH_CALLBACK_BASE_URL=http://localhost:4000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# identity-service — accounts DB (M6 database-per-service)
PORT=4001
MONGO_URI=mongodb://localhost:27017/identity

JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173

# Service-to-service auth (must match profile-service + connection-service).
INTERNAL_SERVICE_TOKEN=dev-internal-token
PROFILE_URL=http://localhost:4005

# Optional. With Redis, emails go to the `email` BullMQ queue (identity-worker).
# REDIS_URL=redis://localhost:6379

SKIP_EMAIL_VERIFICATION=false
EMAIL_USER=
EMAIL_PASS=

# Required for OAuth (64 hex chars).
ENCRYPTION_KEY=

OAUTH_CALLBACK_BASE_URL=http://localhost:4000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

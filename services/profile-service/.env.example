# profile-service — profile, discovery feed, image uploads, enrichment (M6)
PORT=4005

# Shared DB (shared-DB phase) — same MongoDB as the monolith.
MONGO_URI=mongodb://localhost:27017/developer-connection

# Must match identity-service / gateway so forwarded tokenVersion checks line up.
JWT_SECRET=change-me

# Optional — distributed tokenVersion revocation check uses the gateway-forwarded
# header; Redis is not required by this service directly.
# REDIS_URL=redis://localhost:6379

# Cloudinary (profile photo + cover uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AES-256-GCM key — used to DECRYPT OAuth access tokens for GitHub/LinkedIn
# enrichment. Must match the monolith / identity-service key (64 hex chars).
ENCRYPTION_KEY=

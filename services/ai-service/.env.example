PORT=4008
# M3 (shared-DB phase): same MongoDB + database as the monolith.
MONGO_URI=mongodb://localhost:27017/ChatApp
# Optional — enables BullMQ offload + 202 "generating" for recommendations.
# Without it, recommendations generate inline (monolith parity).
REDIS_URL=
INTERNAL_AUTH_HEADER=x-internal-user
INTERNAL_TOKEN_VERSION_HEADER=x-internal-token-version
# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_DAILY_LIMIT=20
# Resume uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

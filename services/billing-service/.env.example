PORT=4007
# M4 (shared-DB phase): same MongoDB + database as the monolith.
MONGO_URI=mongodb://localhost:27017/ChatApp
# Optional — shared rate-limit store across instances. No-op when unset.
REDIS_URL=
INTERNAL_AUTH_HEADER=x-internal-user
INTERNAL_TOKEN_VERSION_HEADER=x-internal-token-version
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
